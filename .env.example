# Wallet API
WALLET_API_TOKEN=your_token_here
WALLET_API_BASE_URL=https://api.budgetbakers.com

# LLM Provider (anthropic, openai, gemini, ollama)
LLM_PROVIDER=openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Optional override

# OpenAI (GPT-4, etc)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o  # Optional override

# Google Gemini
GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-2.0-flash  # Optional override

# Ollama (local, self-hosted)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2  # or mistral, neural-chat, etc

# Gmail / Email
EMAIL_PROVIDER=gmail  # or imap
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# For IMAP (works with ANY email provider)
# Pick your provider and uncomment:

# Gmail
# IMAP_HOST=imap.gmail.com
# IMAP_EMAIL=your_email@gmail.com
# IMAP_PASSWORD=your_app_password  # From myaccount.google.com/apppasswords

# Outlook / Office 365
# IMAP_HOST=imap-mail.outlook.com
# IMAP_EMAIL=your_email@outlook.com
# IMAP_PASSWORD=your_password

# Yahoo Mail
# IMAP_HOST=imap.mail.yahoo.com
# IMAP_EMAIL=your_email@yahoo.com
# IMAP_PASSWORD=your_app_password  # From myaccount.yahoo.com/account/security

# ProtonMail
# IMAP_HOST=imap.protonmail.com
# IMAP_EMAIL=your_email@protonmail.com
# IMAP_PASSWORD=your_password

# Apple iCloud
# IMAP_HOST=imap.mail.me.com
# IMAP_EMAIL=your_email@icloud.com
# IMAP_PASSWORD=your_app_password  # From appleid.apple.com/account/security

# Zoho Mail
# IMAP_HOST=imap.zoho.com
# IMAP_EMAIL=your_email@zohomail.com
# IMAP_PASSWORD=your_password

# Corporate Email (ask your IT admin for IMAP server)
# IMAP_HOST=mail.company.com
# IMAP_EMAIL=your_email@company.com
# IMAP_PASSWORD=your_password

# Self-Hosted / Custom
# IMAP_HOST=your-mail-server.com
# IMAP_EMAIL=your_email@your-domain.com
# IMAP_PASSWORD=your_password

IMAP_PORT=993  # Standard IMAP port (TLS)

# Pipeline
PIPELINE_RUN_INTERVAL_MINUTES=15
PIPELINE_DRY_RUN=false
LOG_LEVEL=INFO
