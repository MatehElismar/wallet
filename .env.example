# ===== WALLET API =====
WALLET_API_TOKEN=your_token_here
WALLET_API_BASE_URL=https://api.budgetbakers.com

# ===== LLM PROVIDER (Choose One) =====
# Pick your LLM provider below

# Option 1: OpenAI (GPT-4o) — Recommended for cost/speed
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o  # Optional override

# Option 2: Anthropic (Claude) — Best accuracy
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Optional override

# Option 3: Google Gemini — Fast + free tier
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-2.0-flash  # Optional override

# Option 4: Ollama (local, private, free)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral  # or llama2, neural-chat, etc

# ===== EMAIL CONFIGURATION =====
# Email is configured in email_accounts.json (both single & multi-account)
# See email_accounts.example.json and MULTI_ACCOUNT.md for setup

EMAIL_PROVIDER=mock  # "mock" for Phase 1, "gmail" for Gmail API, "imap" for single IMAP account

# Gmail API only (if EMAIL_PROVIDER=gmail)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Single IMAP account only (if EMAIL_PROVIDER=imap)
# These are optional and mainly for backwards compatibility
# Recommended: Use email_accounts.json instead
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_EMAIL=your_email@gmail.com
# IMAP_PASSWORD=your_app_password

# ===== PIPELINE SETTINGS =====
PIPELINE_RUN_INTERVAL_MINUTES=15
PIPELINE_DRY_RUN=false
LOG_LEVEL=INFO
