# Wallet API
WALLET_API_TOKEN=your_token_here
WALLET_API_BASE_URL=https://api.budgetbakers.com

# LLM Provider (anthropic, openai, gemini, ollama)
LLM_PROVIDER=openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Optional override

# OpenAI (GPT-4, etc)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o  # Optional override

# Google Gemini
GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-2.0-flash  # Optional override

# Ollama (local, self-hosted)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2  # or mistral, neural-chat, etc

# Gmail / Email
EMAIL_PROVIDER=gmail  # or imap
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# For IMAP
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your_email@gmail.com
IMAP_PASSWORD=your_app_password

# Pipeline
PIPELINE_RUN_INTERVAL_MINUTES=15
PIPELINE_DRY_RUN=false
LOG_LEVEL=INFO
